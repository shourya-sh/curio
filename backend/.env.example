# Postgres connection string (Supabase: Project Settings > Database > URI; use pooler or direct as needed).
# If the backend runs in Docker and you see "could not translate host name", try Session pooler host from the dashboard
# or set DNS on the backend service (see docker-compose.yml).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

AZURE_FOUNDRY_URL=https://your-resource.openai.azure.com/
AZURE_FOUNDRY_API_KEY=your-azure-key-here
# Gemini key pool. Pick ONE of these:
#   (a) GEMINI_API_KEYS=AIza...,AIza...,AIza...   ← multi-key, comma separated
#   (b) GEMINI_API_KEY_1=AIza...                  ← numbered slots (1..20)
#       GEMINI_API_KEY_2=AIza...
#   (c) GEMINI_API_KEY=AIza...                    ← single key, only used if neither above is set
# When GEMINI_API_KEYS or numbered keys exist, GEMINI_API_KEY is IGNORED on purpose.
GEMINI_API_KEY=key_here
# Default model is gemini-2.5-flash-lite (highest free-tier RPM/RPD on new projects).
# Override if you want, e.g. gemini-2.5-flash. gemini-2.0-flash often returns
# "limit: 0" on the free tier of new accounts — don't set it as the default.
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash-lite

# Takes fallbacks so you only need one of Gemini or Azure (see ai.py for routing).

# Supabase Auth — grab from Supabase dashboard > Settings > API
SUPABASE_JWT_SECRET='your-jwt-secret-here'

# Supabase Admin — needed for account deletion (Settings > API > service_role key)
SUPABASE_URL='https://your-project.supabase.co'
SUPABASE_SERVICE_ROLE_KEY='your-service-role-key-here'

# Fernet key for encrypting stored API keys. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY='your-fernet-key-here'